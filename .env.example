# ==== Owner (OPSIONAL) ====
# TIDAK WAJIB diisi! Nomor tempat bot ini login (scan QR) OTOMATIS jadi owner —
# cukup chat bot lewat fitur "Message Yourself" di WhatsApp (chat ke diri sendiri).
# Owner itu lalu bisa tambah owner lain pakai command .setowner @user (tag/reply).
# Variabel ini cuma fallback tambahan opsional & tidak selalu akurat karena WhatsApp
# sekarang sering pakai @lid (ID privasi) yang bukan format nomor asli.
OWNER_NUMBERS=

# Prefix command bot
PREFIX=.

# Link grup yang akan dikirim ke orang yang chat pribadi ke bot
GROUP_INVITE_LINK=https://chat.whatsapp.com/xxxxxxxxxxxxxxxxxxxx

# Info pricelist yang dikirim ke chat pribadi
PRICE_TEXT=Rp. 10.000/bulan
PRICE_CONTACT=contact@juuone.me

# Teks kecil (footer) yang muncul di pesan bertombol
FOOTER_TEXT=© MCPATCH.ME 2026

# Tombol interaktif native WhatsApp (quick reply, list "Pilih Menu", cta_url) - EKSPERIMENTAL.
# Kalau bikin masalah (pesan gagal terkirim / error terus), set ke false untuk balik ke menu teks biasa yang stabil.
ENABLE_NATIVE_BUTTONS=true

# ==== Database Turso (WAJIB, biar data tidak hilang saat Render redeploy) ====
# Bisa disetup lewat CLI ATAU lewat web dashboard di https://turso.tech (tanpa CLI)
TURSO_DATABASE_URL=libsql://nama-db-kamu.turso.io
TURSO_AUTH_TOKEN=isi-token-turso-kamu

# ==== Untuk hosting di Render ====
PORT=3000
# Isi dengan URL render kamu sendiri (https://nama-app.onrender.com) supaya bot bisa self-ping juga (opsional, backup dari cron-job.org)
SELF_URL=

# Delay (detik) sebelum member benar-benar dikeluarkan setelah pesan tag+alasan dikirim
KICK_DELAY_SECONDS=5
